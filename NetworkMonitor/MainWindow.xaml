                                <Button Content="停止" Margin="5,0,0,0" Padding="8,2" Background="#FF3D71" Foreground="{DynamicResource TextMainBrush}" BorderThickness="0" Cursor="Hand" Click="BtnStopRot_Click"/>
                            </StackPanel>
                            <Button Content="📂 导入本地地图贴图" Margin="0,0,0,10" Padding="8,5" Background="{DynamicResource BgInputBrush}" Foreground="#00E5FF" BorderThickness="1" BorderBrush="{DynamicResource BorderMainBrush}" Click="BtnImportMap_Click" Cursor="Hand"/>
                            <CheckBox x:Name="ChkHighResMap" Content="🎨 高清模式" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Checked="ChkHighResMap_CheckedChanged" Unchecked="ChkHighResMap_CheckedChanged"/>
                            <TextBlock Text=" 极限宽度:" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Margin="10,0,5,0"/>
                            <TextBox x:Name="TxtMaxRes" Text="8192" Width="60" Height="20" 
             Background="{DynamicResource BgInputBrush}" 
             Foreground="{DynamicResource TextMainBrush}" 
             BorderThickness="1" BorderBrush="{DynamicResource BorderMainBrush}"
             VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
             TextChanged="TxtMaxRes_TextChanged"/>
                            <TextBlock Text=" px" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text=" 操作指南:" Foreground="{DynamicResource TextDimBrush}" FontSize="11" VerticalAlignment="Center" Margin="15,0,0,0"/>
                            <TextBlock Text=" 滚轮缩放 / 拖拽平移 / 勾选高清模式享受无限细节" Foreground="#666" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Row="3" Content="退出追踪模式" Padding="10" Background="#FF2277" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold" Margin="0,15,0,0" Click="BtnCloseEarth_Click" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </Border>
            </Grid>
            <Grid x:Name="ViewLauncher" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource BgMainBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🚀 应用时光机 (Time Machine)" Foreground="{DynamicResource TextMainBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="点击时间快捷键，或输入具体时刻，主屏幕将瞬间回到过去，展示您当时正在使用的软件工作流组合。" Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,15"/>

                        <WrapPanel Margin="0,0,0,15" VerticalAlignment="Center">
                            <Button Content="Now" Tag="0" Padding="15,6" Margin="0,0,10,10" Click="BtnAdjustTime_Click" Background="{DynamicResource BgNavBrush}" Foreground="{DynamicResource TextMainBrush}" BorderBrush="#00E5FF" BorderThickness="1"/>
                            <Button Content="-5分钟" Tag="-5" Padding="12,6" Margin="0,0,10,10" Click="BtnAdjustTime_Click" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}"/>
                            <Button Content="-30分钟" Tag="-30" Padding="12,6" Margin="0,0,10,10" Click="BtnAdjustTime_Click" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}"/>
                            <Button Content="-1小时" Tag="-60" Padding="12,6" Margin="0,0,10,10" Click="BtnAdjustTime_Click" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}"/>
                            <Button Content="-3小时" Tag="-180" Padding="12,6" Margin="0,0,10,10" Click="BtnAdjustTime_Click" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}"/>
                            <Button Content="昨日此时" Tag="-1440" Padding="12,6" Margin="0,0,10,10" Click="BtnAdjustTime_Click" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}"/>
                        </WrapPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="精准定位: " Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <DatePicker x:Name="DatePickerSnapshot" Width="130" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="0" VerticalContentAlignment="Center"/>
                            <TextBox x:Name="TxtSnapshotTime" Width="85" Text="12:00:00" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" Margin="10,0,0,0" Padding="5" VerticalContentAlignment="Center"/>
                            <Button Content="🔍 生成快照" Click="BtnQuerySnapshot_Click" Margin="15,0,0,0" Padding="20,8" Background="{DynamicResource BgNavBrush}" Foreground="{DynamicResource TextMainBrush}" BorderBrush="#FF2277" BorderThickness="1" FontWeight="Bold" Cursor="Hand"/>
                            <Button Content="⚡ 一键全部唤醒" Click="BtnLaunchAll_Click" Margin="15,0,0,0" Padding="20,8" Background="{DynamicResource BgNavBrush}" Foreground="{DynamicResource TextMainBrush}" BorderBrush="#00E5FF" BorderThickness="1" FontWeight="Bold" Cursor="Hand"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource BgMainBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="6" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="TxtLauncherListTitle" Text="🕒 软件运行记录" Foreground="{DynamicResource TextMainBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                        <DataGrid x:Name="GridAppLogs" Grid.Row="1" AutoGenerateColumns="False" HeadersVisibility="None" Background="Transparent" RowBackground="{DynamicResource BgNavBrush}" IsReadOnly="True" GridLinesVisibility="None" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="10,8">
                                                <Image Source="{Binding Icon}" Width="28" Height="28" Margin="0,0,15,0"/>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold" FontSize="15" ToolTip="{Binding ToolTipText}"/>
                                                        <Border Background="{DynamicResource BgCardBrush}" CornerRadius="4" Padding="6,1" Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColorBrush}" FontSize="11"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding TimeRange}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding ExePath}" Foreground="#555" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="独立唤醒" Tag="{Binding ExePath}" Click="BtnLaunchApp_Click" Background="{DynamicResource BgNavBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="1" BorderBrush="#00E5FF" Padding="12,6" VerticalAlignment="Center" Cursor="Hand"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="ViewLog" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="{DynamicResource BgNavBrush}" CornerRadius="6" Padding="0,15,0,15">
                    <ListBox x:Name="LogCategoryList" Background="Transparent" BorderThickness="0" SelectionChanged="LogCategoryList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="220" Margin="15,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" Foreground="{Binding ColorBrush}" FontWeight="{Binding FontWeight}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CountDisplay}" Foreground="{Binding ColorBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Grid Grid.Column="1" Margin="15,0,0,0">
                    <Border Background="{DynamicResource BgCardBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderMainBrush}" CornerRadius="6">
                        <Grid>
                            <ListBox x:Name="LogListBox" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="10" Visibility="Visible">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Background="Transparent">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgInputBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BgNavBrush}" CornerRadius="6" Padding="15" Margin="0,0,0,8" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Margin="0,0,15,0">
                                                    <Ellipse Width="36" Height="36" Fill="{Binding ColorBrush}"/>
                                                    <TextBlock Text="{Binding IconText}" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                                                </Grid>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text="{Binding Message}" Foreground="{DynamicResource TextDimBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TimeDisplay}" Foreground="{DynamicResource TextDimBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <DataGrid x:Name="GridFileLogs" Visibility="Collapsed" AutoGenerateColumns="False" HeadersVisibility="None" Background="Transparent" RowBackground="{DynamicResource BgNavBrush}" IsReadOnly="True" GridLinesVisibility="None" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="10,8">
                                                    <Image Source="{Binding Icon}" Width="26" Height="26" Margin="0,0,15,0"/>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold" FontSize="14" ToolTip="{Binding ToolTipText}"/>
                                                            <Border Background="{DynamicResource BgCardBrush}"  CornerRadius="4" Padding="6,1" Margin="10,0,0,0">
                                                                <TextBlock Text="{Binding ActionType}" Foreground="{Binding ActionColorBrush}" FontSize="11" FontWeight="Bold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding TimeDisplay}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,4,0,0"/>
                                                        <TextBlock Text="{Binding FilePath}" Foreground="#888" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="📂 定位位置" Tag="{Binding FilePath}" Click="BtnLocateFile_Click" Background="{DynamicResource BgNavBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="1" BorderBrush="#00E5FF" Padding="8,4" VerticalAlignment="Center" Cursor="Hand"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <Grid x:Name="ViewScanner" Visibility="Collapsed" Background="{DynamicResource BgMainBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <RadioButton x:Name="RadioFilterAll" Content="All 0" IsChecked="True" Foreground="#8BC34A" Background="#228BC34A" Padding="15,6" Margin="0,0,10,0" Click="ScannerFilter_Click" Cursor="Hand">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border Background="{TemplateBinding Background}" CornerRadius="12" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                        <Setter Property="BorderBrush" Value="#8BC34A"/>
                                        <Setter Property="Background" Value="#448BC34A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>

                    <RadioButton x:Name="RadioFilterActive" Content="Active 0" Foreground="{DynamicResource TextMainBrush}" Background="#11888888" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" Padding="15,6" Margin="0,0,15,0" Click="ScannerFilter_Click" Cursor="Hand">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="ActiveBorder" Background="{TemplateBinding Background}" CornerRadius="12" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="ActiveBorder" Property="Background" Value="#33888888"/>
                                        <Setter TargetName="ActiveBorder" Property="BorderBrush" Value="{DynamicResource TextMainBrush}"/>
                                        <Setter TargetName="ActiveBorder" Property="BorderThickness" Value="1.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>

                    <Button x:Name="BtnScan" Content="🔄 一键深度扫描" Padding="20,5" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" Foreground="{DynamicResource TextMainBrush}" Click="BtnScan_Click" Cursor="Hand" Margin="0,0,10,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="BtnScannerSettings" Content="⚙️ 设置" Padding="15,5" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" Foreground="{DynamicResource TextMainBrush}" Click="BtnScannerSettings_Click" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <Border Grid.Row="1" x:Name="ScannerSettingsPanel" Visibility="Collapsed" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Network Scanner Settings" Foreground="{DynamicResource TextMainBrush}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Auto-scan the network every" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtAutoScanMins" Width="40" Margin="10,0" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="0" TextAlignment="Center" TextChanged="ScannerSettings_Changed"/>
                            <TextBlock Text="minutes" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Threads quantity: " Foreground="{DynamicResource TextDimBrush}" Margin="0,0,5,0"/>
                            <TextBlock x:Name="TxtThreadsValue" Text="32" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock Text="Fewer threads increase the accuracy of the scan, but take longer to scan." Foreground="#888" FontSize="11" Margin="0,5,0,10"/>
                        <Slider x:Name="SliderThreads" Minimum="1" Maximum="256" Value="32" Width="300" HorizontalAlignment="Left" Margin="0,0,0,20" ValueChanged="ScannerSettings_Changed"/>

                        <TextBlock Text="Used Protocols:" Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <CheckBox x:Name="ChkProtoDHCP" Content="DHCP" Foreground="{DynamicResource TextMainBrush}" IsChecked="True" Margin="0,0,20,0" Checked="ScannerSettings_Changed" Unchecked="ScannerSettings_Changed"/>
                            <CheckBox x:Name="ChkProtoSNMP" Content="SNMP" Foreground="{DynamicResource TextMainBrush}" IsChecked="True" Margin="0,0,20,0" Checked="ScannerSettings_Changed" Unchecked="ScannerSettings_Changed"/>
                            <CheckBox x:Name="ChkProtoMDNS" Content="MDNS" Foreground="{DynamicResource TextMainBrush}" IsChecked="True" Margin="0,0,20,0" Checked="ScannerSettings_Changed" Unchecked="ScannerSettings_Changed"/>
                            <CheckBox x:Name="ChkProtoSSDP" Content="SSDP" Foreground="{DynamicResource TextMainBrush}" IsChecked="True" Checked="ScannerSettings_Changed" Unchecked="ScannerSettings_Changed"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
                    <ItemsControl x:Name="ScannerInterfacesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,0,15">
                                    <StackPanel>
                                        <Grid Background="{DynamicResource BgNavBrush}" Cursor="Hand" PreviewMouseLeftButtonDown="ScannerInterfaceHeader_Click">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="24" Height="24" Background="#8BC34A" CornerRadius="4" Margin="0,0,10,0">
                                                <TextBlock Text="🔌" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>

                                            <Button Grid.Column="2" Content="🔄 单独扫描此网卡" Tag="{Binding MAC}" Click="BtnScanSingle_Click" Background="Transparent" Foreground="#8BC34A" BorderThickness="1" BorderBrush="#8BC34A" Padding="8,2" Margin="0,0,15,0" Cursor="Hand"/>

                                            <TextBlock Grid.Column="3" Text="{Binding ScannedTime}" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                            <TextBlock Grid.Column="4" Text="{Binding ExpandIcon}" Foreground="#00E5FF" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Grid>
                                        <StackPanel Visibility="{Binding ExpandedVisibility}">
                                            <Grid Margin="0,15,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="Description:" Foreground="{DynamicResource TextDimBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Description}" Foreground="{DynamicResource TextMainBrush}" TextWrapping="Wrap"/>

                                                <TextBlock Grid.Row="1" Text="MAC:" Foreground="{DynamicResource TextDimBrush}" Margin="0,15,0,0"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MAC}" Foreground="{DynamicResource TextMainBrush}" Margin="0,15,0,0"/>

                                                <TextBlock Grid.Row="2" Text="DNS Servers:" Foreground="{DynamicResource TextDimBrush}" Margin="0,15,0,0"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DnsServers}" Foreground="{DynamicResource TextMainBrush}" Margin="0,15,0,0"/>

                                                <TextBlock Grid.Column="2" Text="IP addresses:" Foreground="{DynamicResource TextDimBrush}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding IPAddresses}" Foreground="{DynamicResource TextMainBrush}"/>

                                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Gateway:" Foreground="{DynamicResource TextDimBrush}" Margin="0,15,0,0"/>
                                                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Gateway}" Foreground="{DynamicResource TextMainBrush}" Margin="0,15,0,0"/>
                                            </Grid>

                                            <DataGrid ItemsSource="{Binding Devices}" AutoGenerateColumns="False" HeadersVisibility="Column" Background="Transparent" RowBackground="Transparent" BorderThickness="0" GridLinesVisibility="None" IsReadOnly="True" Margin="0,0,0,15" PreviewMouseWheel="InnerDataGrid_PreviewMouseWheel">
                                                <DataGrid.RowStyle>
                                                    <Style TargetType="DataGridRow">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGrid.RowStyle>
                                                <DataGrid.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="DataGridCell">
                                                                    <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="5,0">
                                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </DataGrid.CellStyle>
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Name" Width="220">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="15,8">
                                                                    <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center" FontWeight="Bold"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>

                                                    <DataGridTextColumn Header="IP &amp; MAC address" Binding="{Binding IPMACDisplay}" Width="200">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>

                                                    <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeen}" Width="150">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                </DataGrid.Columns>
                                                <DataGrid.ColumnHeaderStyle>
                                                    <Style TargetType="DataGridColumnHeader">
                                                        <Setter Property="Background" Value="{DynamicResource BgNavBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
                                                        <Setter Property="Padding" Value="15,10,0,10"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </Style>
                                                </DataGrid.ColumnHeaderStyle>
                                            </DataGrid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            <Grid x:Name="ViewSettings" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Background="{DynamicResource BgMainBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="6" Padding="25" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="✨ 样式预览 (Preview):" Foreground="{DynamicResource TextDimBrush}" Margin="0,10,0,5"/>
                        <Border Background="{DynamicResource BgNavBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                            <StackPanel x:Name="ThemePreviewArea">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock x:Name="PreviewLabelDown" Text="下载: 1.25 MB/s" FontWeight="Bold" Margin="0,0,20,0"/>
                                    <TextBlock x:Name="PreviewLabelUp" Text="上传: 450 KB/s" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="PreviewLabelCpu" Text="CPU: 15.5%" FontWeight="Bold" Margin="0,0,20,0"/>
                                    <TextBlock x:Name="PreviewLabelRam" Text="RAM: 42.1%" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock x:Name="PreviewTextSample" Text="文本预览: System DashBoard 控制面板" Foreground="{DynamicResource TextDimBrush}" Margin="0,10,0,0" FontSize="12" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="个性化主题配置" Foreground="{DynamicResource TextMainBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                        <TextBlock Text="3D 路由追踪球体透明度:" Foreground="{DynamicResource TextDimBrush}"/>
                        <Slider x:Name="SliderEarthOpacity" Minimum="0.2" Maximum="1.0" Value="0.9" Margin="0,5,0,15"/>
                        <TextBlock Text="全局字体大小:" Foreground="{DynamicResource TextDimBrush}"/>
                        <Slider x:Name="SliderFontSize" Minimum="10" Maximum="20" Value="14" Margin="0,5,0,20"/>

                            <TextBlock Text="🎨 预设主题快捷选择:" Foreground="{DynamicResource TextDimBrush}" Margin="0,10,0,5"/>
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="🌓 环境氛围 (仅切换深/浅色背景，保留当前线条颜色)" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button Content="Daylight Theme" Tag="#F5F6F8,#FFFFFF" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Asphalt Theme" Tag="#1e1e24,#2b2b36" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Night Neon Theme" Tag="#090A0F,#151720" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="🌈 监控配色 (仅切换曲线颜色，背景保持不变)" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button Content="Orange &amp; Plum" Tag="#FF8C00,#DDA0DD,#FF4500,#800080" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Orange &amp; Orchid" Tag="#FF9800,#DA70D6,#FF5722,#9932CC" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Aqua &amp; Pink" Tag="#00E5FF,#FF69B4,#00BFFF,#FF1493" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Green &amp; Pink" Tag="#00FA9A,#FF69B4,#32CD32,#FF1493" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Blue &amp; Peach" Tag="#1E90FF,#FFDAB9,#4169E1,#FFA07A" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Green &amp; Iris" Tag="#00FF7F,#5A4FCF,#2E8B57,#483D8B" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Lemon &amp; Lime" Tag="#FFF700,#32CD32,#FFD700,#00FA9A" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Lilac &amp; Mint" Tag="#C8A2C8,#98FF98,#DDA0DD,#00FF7F" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Orlok &amp; Ellen" Tag="#8A0303,#D3D3D3,#800000,#A9A9A9" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                    <Button Content="Candies &amp; Bubblegum" Tag="#FF1493,#00BFFF,#FF69B4,#00FFFF" Padding="12,6" Background="{DynamicResource BgCardBrush}" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                </WrapPanel>
                            </StackPanel>
                            <TextBlock Text="资源监控面板组件显隐:" Foreground="{DynamicResource TextDimBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,20">
                                <CheckBox x:Name="ChkShowCpu" Content="CPU" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,15,0" Checked="ResToggle_Changed" Unchecked="ResToggle_Changed"/>
                                <CheckBox x:Name="ChkShowRam" Content="RAM" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,15,0" Checked="ResToggle_Changed" Unchecked="ResToggle_Changed"/>
                                <CheckBox x:Name="ChkShowGpu" Content="GPU" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,15,0" Checked="ResToggle_Changed" Unchecked="ResToggle_Changed"/>
                                <CheckBox x:Name="ChkShowDisk" Content="磁盘 (Disk)" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,15,0" Checked="ResToggle_Changed" Unchecked="ResToggle_Changed"/>
                                <CheckBox x:Name="ChkShowBat" Content="电量 (Bat)" Foreground="{DynamicResource TextMainBrush}" Checked="ResToggle_Changed" Unchecked="ResToggle_Changed"/>
                            </StackPanel>

                            <TextBlock Text="流量图表显示日志标记 (Chart Log Markers):" Foreground="{DynamicResource TextDimBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,20">
                                <CheckBox x:Name="ChkLogSystem" Content="系统提醒" IsChecked="True" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,15,0" Checked="LogMarkerToggle_Changed" Unchecked="LogMarkerToggle_Changed"/>
                                <CheckBox x:Name="ChkLogApp" Content="应用记录" IsChecked="True" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,15,0" Checked="LogMarkerToggle_Changed" Unchecked="LogMarkerToggle_Changed"/>
                                <CheckBox x:Name="ChkLogNet" Content="网络扫描" IsChecked="True" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,15,0" Checked="LogMarkerToggle_Changed" Unchecked="LogMarkerToggle_Changed"/>
                                <CheckBox x:Name="ChkLogOther" Content="其他" IsChecked="False" Foreground="{DynamicResource TextMainBrush}" Checked="LogMarkerToggle_Changed" Unchecked="LogMarkerToggle_Changed"/>
                            </StackPanel>

                            <TextBlock Text="悬停进程解释显示 (Hover Tooltip):" Foreground="{DynamicResource TextDimBrush}"/>

                            <ComboBox x:Name="ComboTooltipMode" Width="220" HorizontalAlignment="Left" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" Margin="0,5,0,20" SelectionChanged="ComboTooltipMode_SelectionChanged">
                                <ComboBoxItem Content="不显示解释" Tag="0"/>
                                <ComboBoxItem Content="仅显示进程名称" Tag="1"/>
                                <ComboBoxItem Content="显示名称与具体描述" Tag="2"/>
                            </ComboBox>
                            <TextBlock Text="进程字典自定义 (支持增加、修改、删除):" Foreground="{DynamicResource TextDimBrush}" Margin="0,15,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="📥 导入 JSON" Click="BtnImportDict_Click" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="0" Padding="15,6" Margin="0,0,10,0" Cursor="Hand"/>
                                <Button Content="📤 导出 JSON" Click="BtnExportDict_Click" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="0" Padding="15,6" Margin="0,0,10,0" Cursor="Hand"/>
                                <Button Content="🔄 恢复默认" Click="BtnResetDict_Click" Background="#FF3D71" Foreground="White" BorderThickness="0" Padding="15,6" Cursor="Hand"/>
                            </StackPanel>

                            <DataGrid x:Name="DictDataGrid" ItemsSource="{Binding DictItemsList, RelativeSource={RelativeSource AncestorType=Window}}" 
          AutoGenerateColumns="False" Background="{DynamicResource BgCardBrush}" RowBackground="{DynamicResource BgNavBrush}" 
          BorderThickness="1" BorderBrush="{DynamicResource BorderMainBrush}" HeadersVisibility="Column" 
          GridLinesVisibility="All" HorizontalGridLinesBrush="{DynamicResource BorderMainBrush}" VerticalGridLinesBrush="{DynamicResource BorderMainBrush}"
          Height="220" HorizontalAlignment="Left" Width="400" CanUserAddRows="True" CanUserDeleteRows="True" 
          CellEditEnding="DictDataGrid_CellEditEnding" Margin="0,0,0,30">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="8,4">
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{DynamicResource BgNavBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
                                        <Setter Property="Padding" Value="10,6"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderMainBrush}"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="进程名" Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                    <DataGridTextColumn Header="具体描述" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="🛠️ 恢复初始化" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,0,0,10"/>
                                <WrapPanel>
                                    <Button Content="Classic (全部还原)" Tag="#FF2277,#00E5FF,#ff3d71,#A142F4,#121216,#18181e" Padding="15,8" Background="{DynamicResource BgNavBrush}" BorderBrush="#4285F4" BorderThickness="1" Margin="0,0,10,10" Click="ThemePreset_Click"/>
                                </WrapPanel>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="5">
                                    <TextBlock Text="下载颜色:" Foreground="{DynamicResource TextDimBrush}"/>
                                    <DockPanel Margin="0,5">
                                        <Border x:Name="PreviewBoxDown" Width="20" Height="20" Margin="5" CornerRadius="2"/>
                                        <TextBox x:Name="EditColorDown" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" Padding="5"/>
                                    </DockPanel>
                                    <TextBlock Text="CPU 颜色:" Foreground="{DynamicResource TextDimBrush}" Margin="0,10,0,0"/>
                                    <DockPanel Margin="0,5">
                                        <Border x:Name="PreviewBoxCpu" Width="20" Height="20" Margin="5" CornerRadius="2"/>
                                        <TextBox x:Name="EditColorCpu" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" Padding="5"/>
                                    </DockPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5">
                                    <TextBlock Text="上传颜色:" Foreground="{DynamicResource TextDimBrush}"/>
                                    <DockPanel Margin="0,5">
                                        <Border x:Name="PreviewBoxUp" Width="20" Height="20" Margin="5" CornerRadius="2"/>
                                        <TextBox x:Name="EditColorUp" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" Padding="5"/>
                                    </DockPanel>
                                    <TextBlock Text="RAM 颜色:" Foreground="{DynamicResource TextDimBrush}" Margin="0,10,0,0"/>
                                    <DockPanel Margin="0,5">
                                        <Border x:Name="PreviewBoxRam" Width="20" Height="20" Margin="5" CornerRadius="2"/>
                                        <TextBox x:Name="EditColorRam" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" Padding="5"/>
                                    </DockPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="5">
                                    <TextBlock Text="主背景色 (Main Bg):" Foreground="{DynamicResource TextDimBrush}"/>
                                    <DockPanel Margin="0,5">
                                        <Border x:Name="PreviewBoxBgMain" Width="20" Height="20" Margin="5" CornerRadius="2"/>
                                        <TextBox x:Name="EditColorBgMain" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" Padding="5"/>
                                    </DockPanel>
                                    <TextBlock Text="面板底色 (Card Bg):" Foreground="{DynamicResource TextDimBrush}" Margin="0,10,0,0"/>
                                    <DockPanel Margin="0,5">
                                        <Border x:Name="PreviewBoxBgCard" Width="20" Height="20" Margin="5" CornerRadius="2"/>
                                        <TextBox x:Name="EditColorBgCard" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" Padding="5"/>
                                    </DockPanel>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="💾 数据管理 (Data Management)" Foreground="{DynamicResource TextMainBrush}" FontSize="20" FontWeight="Bold" Margin="0,35,0,10"/>
                            <Border Background="{DynamicResource BgNavBrush}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="📥 导入历史数据" Padding="20,10" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="1" BorderBrush="#00E5FF" Cursor="Hand" Click="BtnImportData_Click" Margin="0,0,20,0"/>
                                    <Button Content="📤 导出备份数据" Padding="20,10" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="1" BorderBrush="#4285F4" Cursor="Hand" Click="BtnExportData_Click" Margin="0,0,20,0"/>
                                    <Button Content="🗑️ 清除所有数据" Padding="20,10" Background="{DynamicResource BgCardBrush}" Foreground="{DynamicResource TextMainBrush}" BorderThickness="1" BorderBrush="#FF2277" Cursor="Hand" Click="BtnDeleteData_Click"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
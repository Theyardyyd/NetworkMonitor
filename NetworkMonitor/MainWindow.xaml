<Window x:Class="NetworkMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System DashBoard v1.8.5" Height="720" Width="1100" 
        Background="{DynamicResource BgMainBrush}" 
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="BgMainBrush" Color="#121216" />
        <SolidColorBrush x:Key="BgCardBrush" Color="#18181e" />
        <SolidColorBrush x:Key="BgNavBrush" Color="#1a1a20" />

        <SolidColorBrush x:Key="TextMainBrush" Color="White" />
        <SolidColorBrush x:Key="TextDimBrush" Color="#aaaaaa" />

        <SolidColorBrush x:Key="BgInputBrush" Color="#222222" />
        <SolidColorBrush x:Key="BorderMainBrush" Color="#333333" />
        <SolidColorBrush x:Key="HeatmapEmptyBrush" Color="#28282d" />
        <SolidColorBrush x:Key="GridLineBrush" Color="#28ffffff" />

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{DynamicResource BgInputBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2d2d35" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White" />
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMainBrush}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BgNavBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMainBrush}"/>
        </Style>

            <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource BgMainBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMainBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0,0,1,0"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource BorderMainBrush}" CornerRadius="3" Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <Border Background="{DynamicResource BgNavBrush}" BorderBrush="#2a2a35" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <TextBlock Text="DASHBOARD" Foreground="{DynamicResource TextMainBrush}" FontSize="18" FontWeight="Black" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="NavTraffic" Content="📊 流量监控" Style="{StaticResource NavButtonStyle}" Click="Nav_Click"/>
                    
                    
                    <Button x:Name="NavSystem" Content="📈 系统概览" Style="{StaticResource NavButtonStyle}" Click="Nav_Click"/>
                    
                    <Button x:Name="NavResources" Content="💻 资源分配" Style="{StaticResource NavButtonStyle}" Click="Nav_Click"/>
                    
                    <Button x:Name="NavLog" Content="🔔 警报与日志" Style="{StaticResource NavButtonStyle}" Click="Nav_Click"/>
                    
                    <Button x:Name="NavLauncher" Content="🚀 应用时光机" Style="{StaticResource NavButtonStyle}" Click="Nav_Click"/>

                    <Button x:Name="NavScanner" Content="🔍 局域网扫描" Style="{StaticResource NavButtonStyle}" Click="Nav_Click"/>
                    <Button x:Name="NavSettings" Content="⚙️ 偏好设置" Style="{StaticResource NavButtonStyle}" Click="Nav_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="20">
            <ScrollViewer x:Name="ViewTraffic" Visibility="Visible" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                <Grid MinHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="250"/>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="0" x:Name="ProcessListRow"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TxtDown" Text="下载: 0 Kbps" Foreground="#FF2277" FontSize="20" FontWeight="Bold" Width="200"/>
                        <TextBlock x:Name="TxtUp" Text="上传: 0 Kbps" Foreground="#00E5FF" FontSize="20" FontWeight="Bold" Width="200"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <StackPanel x:Name="CustomTimePanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,10,0">
                            <TextBox x:Name="TxtCustomTime" Width="60" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextMainBrush}" Text="60" Padding="2" VerticalContentAlignment="Center"/>
                            <TextBlock Text="秒" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" Margin="5,0"/>
                            <Button Content="应用" Click="BtnApplyCustomTime_Click" Background="#FF2277" Foreground="{DynamicResource TextMainBrush}" BorderThickness="0" Padding="10,2" Cursor="Hand"/>
                        </StackPanel>

                        <ComboBox x:Name="TimeWindowCombo" Width="100" Margin="0,0,15,0" Padding="5,2" Background="{DynamicResource BgMainBrush}" Foreground="{DynamicResource TextMainBrush}" BorderBrush="{DynamicResource BorderMainBrush}" SelectionChanged="TimeWindowCombo_SelectionChanged">
                            <ComboBoxItem Content="1 分钟" Tag="60" IsSelected="True"/>
                            <ComboBoxItem Content="5 分钟" Tag="300" />
                            <ComboBoxItem Content="30 分钟" Tag="1800"/>
                            <ComboBoxItem Content="3 小时" Tag="10800"/>
                            <ComboBoxItem Content="24 小时" Tag="86400"/>
                            <ComboBoxItem Content="7 天" Tag="604800"/>
                            <ComboBoxItem Content="30 天" Tag="2592000"/>
                            <ComboBoxItem Content="自定义..." Tag="-1"/>
                        </ComboBox>
                        <Button Content="🔄 UNIT: BIT / BYTE" Padding="15,5" Background="{DynamicResource BgMainBrush}" Foreground="#00E5FF" BorderBrush="{DynamicResource BorderMainBrush}" Click="BtnToggleUnit_Click" Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" Background="{DynamicResource BgMainBrush}" CornerRadius="6" ClipToBounds="True">
                        <Canvas x:Name="MainCanvas" Background="Transparent" MouseMove="MainCanvas_MouseMove" MouseLeave="MainCanvas_MouseLeave" MouseLeftButtonDown="MainCanvas_MouseLeftButtonDown" MouseLeftButtonUp="MainCanvas_MouseLeftButtonUp" SizeChanged="MainCanvas_SizeChanged">
                            <Rectangle x:Name="ChartSelectionRect" Fill="#4400E5FF" Visibility="Hidden" IsHitTestVisible="False" Canvas.Top="0" Height="1000"/>
                            <TextBlock x:Name="LabelMax" Text="10 MB/s" Foreground="#A0FFFFFF" FontWeight="Bold" Canvas.Top="10" Canvas.Left="10" Panel.ZIndex="100"/>
                            <Polygon x:Name="PolyDown" Fill="#15FF2277" Stroke="#FF2277" StrokeThickness="1.5" />
                        <Polygon x:Name="PolyUp" Fill="#1500E5FF" Stroke="#00E5FF" StrokeThickness="1.5" />
                        <Line x:Name="MainHoverLine" Stroke="Gray" StrokeDashArray="2 2" Y1="0" Y2="1000" Visibility="Hidden" IsHitTestVisible="False"/>
                        <Ellipse x:Name="MainHoverDotDown" Width="8" Height="8" Fill="#FF2277" Stroke="White" Visibility="Hidden" Margin="-4,-4,0,0"/>
                        <Ellipse x:Name="MainHoverDotUp" Width="8" Height="8" Fill="#00E5FF" Stroke="White" Visibility="Hidden" Margin="-4,-4,0,0"/>
                            <Border x:Name="MainHoverPopup" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="4" Padding="10,5" Visibility="Hidden" IsHitTestVisible="False" Panel.ZIndex="100">
                                <StackPanel>
                                <TextBlock x:Name="MainHoverTime" Foreground="{DynamicResource TextMainBrush}" FontSize="14" FontWeight="Bold"/>
                                <TextBlock x:Name="MainHoverDownText" Foreground="#FF2277" FontWeight="Bold"/>
                                <TextBlock x:Name="MainHoverUpText" Foreground="#00E5FF" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Canvas>
                </Border>
                <Grid Grid.Row="2" Margin="10,15,10,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock x:Name="TxtWinDownTotal" Text="0 B" Foreground="{DynamicResource TextMainBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="TxtWinDownSpeed" Text="0 B/s" Foreground="{DynamicResource TextDimBrush}" FontSize="12" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                    
                    </StackPanel>
                    <Path x:Name="ArrowWinDown" Grid.Column="1" Data="M 0,0 L 5,5 L 10,0" Stroke="#FF2277" StrokeThickness="2.5" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,-22,18"/>

                    <Canvas Grid.Column="2" Width="140" Height="70" VerticalAlignment="Bottom" Margin="15,0">
                        <Path Stroke="#333" StrokeThickness="8" StrokeEndLineCap="Round" StrokeStartLineCap="Round" Data="M 20,65 A 50,50 0 0 1 120,65"/>
                        <Path x:Name="PathWinDown" Stroke="#FF2277" StrokeThickness="8" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                        <Path x:Name="PathWinUp" Stroke="#00E5FF" StrokeThickness="8" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>

                        <StackPanel Canvas.Left="0" Canvas.Top="32" Width="140" HorizontalAlignment="Center">
                            <Path Data="M 5,10 a 5,5 0 1,1 10,0 a 5,5 0 1,1 -10,0 M 10,2 L 10,5 M 10,15 L 10,18 M 2,10 L 5,10 M 15,10 L 18,10" Stroke="Gray" Stretch="Uniform" Width="14" Height="14" Margin="0,0,0,2"/>
                            <TextBlock x:Name="TxtWinTotal" Text="0 B" Foreground="{DynamicResource TextMainBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Canvas>

                    <Path x:Name="ArrowWinUp" Grid.Column="3" Data="M 0,5 L 5,0 L 10,5" Stroke="#00E5FF" StrokeThickness="2.5" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-22,18,0,0"/>
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock x:Name="TxtWinUpTotal" Text="0 B" Foreground="{DynamicResource TextMainBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="TxtWinUpSpeed" Text="0 B/s" Foreground="{DynamicResource TextDimBrush}" FontSize="12" HorizontalAlignment="Left" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Rectangle Grid.Column="5" Fill="#333" Width="1" Height="50" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="7" VerticalAlignment="Center" Margin="0,0,0,0">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="WAN" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtWanTotal" Grid.Column="1" Text="0 B" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Height="6" Background="#333" CornerRadius="3" ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="ColWanDown" Width="0*"/>
                                        <ColumnDefinition x:Name="ColWanUp" Width="0*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle x:Name="RectWanDown" Fill="#FF2277" Grid.Column="0"/>
                                    <Rectangle x:Name="RectWanUp" Fill="#00E5FF" Grid.Column="1"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="LAN" Foreground="{DynamicResource TextDimBrush}" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtLanTotal" Grid.Column="1" Text="0 B" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Height="6" Background="#333" CornerRadius="3" ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="ColLanDown" Width="0*"/>
                                        <ColumnDefinition x:Name="ColLanUp" Width="0*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle x:Name="RectLanDown" Fill="#FF2277" Grid.Column="0"/>
                                    <Rectangle x:Name="RectLanUp" Fill="#00E5FF" Grid.Column="1"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>


                    <StackPanel Grid.Row="3" Margin="0,15,0,0" HorizontalAlignment="Center">
                        <TextBlock x:Name="TxtSelectedTimeRange" Foreground="#00E5FF" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Visibility="Collapsed" Margin="0,0,0,8" />
                        <Button x:Name="BtnToggleProcess" Content="▼ 展开进程详情" Padding="15,5" Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource TextDimBrush}" Click="BtnToggleProcess_Click"/>
                    </StackPanel>
                    <Grid Grid.Row="4" Margin="0,10,0,0">
                        <DataGrid x:Name="ProcessGrid" LoadingRowDetails="ProcessGrid_LoadingRowDetails" AutoGenerateColumns="False" Background="{DynamicResource BgMainBrush}" RowBackground="{DynamicResource BgNavBrush}" Foreground="{DynamicResource TextDimBrush}" HeadersVisibility="Column" RowDetailsVisibilityMode="VisibleWhenSelected" ScrollViewer.CanContentScroll="False">
                            <DataGrid.Columns>
                            <DataGridTextColumn Header="进程名称" Binding="{Binding DisplayName, Mode=OneWay}" Width="200" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="ToolTip" Value="{Binding ToolTipText, Mode=OneWay}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="▼ 下载总量" Binding="{Binding DownloadDisplay}" SortMemberPath="RawDownload" Width="120" Foreground="#FF2277"/>
                            <DataGridTextColumn Header="▲ 上传总量" Binding="{Binding UploadDisplay}" SortMemberPath="RawUpload" Width="120" Foreground="#00E5FF"/>
                            <DataGridTextColumn Header="IP连接数" Binding="{Binding ConnectionCount}" Width="80"/>
                            <DataGridTextColumn Header="活动状态" Binding="{Binding State}" Width="*"/>
                        </DataGrid.Columns>

                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource BgInputBrush}" Padding="20,10,10,10" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="0,1,0,1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <TextBlock Text="进程详细信息 (Process Details)" Foreground="{DynamicResource TextDimBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>

                                                <Button Content="✖ 收起详情" HorizontalAlignment="Right" Background="Transparent" Foreground="#FF2277" BorderThickness="0" Cursor="Hand" Click="BtnCloseDetails_Click"/>
                                        </Grid>

                                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource TextMainBrush}" FontSize="16" FontWeight="Bold"/>
                                            <TextBlock x:Name="TxtProcessPath" Text="{Binding ProcessPath}" Foreground="{DynamicResource TextDimBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="TxtProcessVersion" Text="{Binding ProcessVersion}" Foreground="{DynamicResource TextDimBrush}" FontSize="11"/>
                                            <TextBlock x:Name="TxtProcessPublisher" Text="{Binding ProcessPublisher}" Foreground="{DynamicResource TextDimBrush}" FontSize="11"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                                            <Button Content="🌍 显示网络连接 IP 详情" Tag="{Binding}" Click="BtnShowIPs_Click" Background="{DynamicResource BgNavBrush}" Foreground="#00E5FF" BorderThickness="1" BorderBrush="#00E5FF" Padding="10,5" Cursor="Hand"/>
                                            <TextBlock Text="⏳ 正在加载选定时间段数据..." Visibility="{Binding LoadingVisibility}" Foreground="#00E5FF" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>


                                                <DataGrid Grid.Row="3" Visibility="{Binding IpGridVisibility}" ItemsSource="{Binding Connections}" AutoGenerateColumns="False" HeadersVisibility="Column" Background="Transparent" RowBackground="Transparent" BorderThickness="0" GridLinesVisibility="None" IsReadOnly="True" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingStackPanel.ScrollUnit="Pixel">
                                                    <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="IP Address" Binding="{Binding IP}" Width="130" />
                                                <DataGridTextColumn Header="Region" Binding="{Binding Region}" Width="200" />
                                                <DataGridTextColumn Header="▼ 下载" Binding="{Binding DownloadDisplay}" Width="80" Foreground="#FF2277"/>
                                                <DataGridTextColumn Header="▲ 上传" Binding="{Binding UploadDisplay}" Width="80" Foreground="#00E5FF"/>
                                                <DataGridTemplateColumn Width="90">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="🌍 3D追踪" Tag="{Binding IP}" Click="BtnTraceIP_Click" Background="{DynamicResource BgNavBrush}" Foreground="#00E5FF" BorderThickness="0" Cursor="Hand" Padding="8,2" Margin="0,2"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>
                    <Border x:Name="PanelProcessLoading" Background="{DynamicResource BgCardBrush}" Visibility="Collapsed" CornerRadius="4" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30,15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏳" FontSize="20" Margin="0,0,10,0"/>
                            <TextBlock Text="正在提取历史流量数据..." Foreground="{DynamicResource TextDimBrush}" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
                </Grid>
            </ScrollViewer>
            <Grid x:Name="ViewSystem" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
                    <Grid Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="200"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="300"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{DynamicResource BgMainBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="6" Padding="15">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="流量使用热力图 (Traffic Contributions)" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="◀" Foreground="{DynamicResource TextDimBrush}" Background="Transparent" Click="BtnPrevYear_Click" BorderThickness="0"/>
                                <TextBlock x:Name="HeatmapYearText" Text="2024" Foreground="{DynamicResource TextMainBrush}" FontWeight="Bold" Margin="10,0" VerticalAlignment="Center"/>
                                <Button Content="▶" Foreground="{DynamicResource TextDimBrush}" Background="Transparent" Click="BtnNextYear_Click" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                        <Canvas x:Name="HeatmapCanvas" Height="140" Background="Transparent"/>
                    </StackPanel>
                </Border>
                <Grid Grid.Row="1" Margin="0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource BgMainBrush}" BorderBrush="#FF2277" BorderThickness="3,0,0,0" Padding="15">
                        <StackPanel>
                            <TextBlock Text="今日流量" Foreground="{DynamicResource TextDimBrush}"/>
                            <TextBlock x:Name="TxtToday" Text="0.00 GB" Foreground="{DynamicResource TextMainBrush}" FontSize="26" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtTodayVpn" Text="VPN: 0 B" Foreground="#FF9800" FontSize="11" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource BgMainBrush}" BorderBrush="#4285F4" BorderThickness="3,0,0,0" Padding="15">
                        <StackPanel>
                            <TextBlock Text="本周流量" Foreground="{DynamicResource TextDimBrush}"/>
                            <TextBlock x:Name="TxtWeek" Text="0.00 GB" Foreground="{DynamicResource TextMainBrush}" FontSize="26" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtWeekVpn" Text="VPN: 0 B" Foreground="#FF9800" FontSize="11" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="{DynamicResource BgMainBrush}" BorderBrush="#A142F4" BorderThickness="3,0,0,0" Padding="15">
                        <StackPanel>
                            <TextBlock Text="本月流量" Foreground="{DynamicResource TextDimBrush}"/>
                            <TextBlock x:Name="TxtMonth" Text="0.00 GB" Foreground="{DynamicResource TextMainBrush}" FontSize="26" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtMonthVpn" Text="VPN: 0 B" Foreground="#FF9800" FontSize="11" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                </Grid>
                <Border Grid.Row="2" Background="{DynamicResource BgMainBrush}" BorderBrush="{DynamicResource BorderMainBrush}" BorderThickness="1" CornerRadius="6" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
